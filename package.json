{
  "name": "statistics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,server,tunnel -c blue,green,yellow \"npm:dev:frontend\" \"npm:dev:server\" \"npm:dev:tunnel\"",
    "dev:frontend": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env.local server/index.ts",
    "dev:tunnel": "tolgee-app dev",
    "register": "tolgee-app register",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pull-context": "node scripts/pull-context.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.1.0",
    "@tginternal/client": "0.0.0-prerelease.c8329b552",
    "@tolgee/apps-sdk": "0.0.1-alpha.7",
    "express": "^4.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tolgee/apps-dev": "0.0.1-alpha.2",
    "@types/express": "^4.17.21",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
